# MTN Intern Leave Tracker Environment Variables

# Application URL (used for email links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email Service Configuration
# Replace with your actual email service credentials in production
# Options: Resend, SendGrid, AWS SES, etc.

# Example for Resend (https://resend.com)
# RESEND_API_KEY=re_xxxxxxxxxxxxx

# Example for SendGrid
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxx

# Database Configuration (when using a real database)
# Example for Supabase
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Example for MongoDB
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database

# Authentication (when using NextAuth.js or similar)
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=your-secret-key-here
